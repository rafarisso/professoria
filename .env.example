# Microsoft Foundry project endpoint.
# Example: https://XXXX.services.ai.azure.com/api/projects/NOME_DO_PROJETO
AZURE_FOUNDRY_ENDPOINT=

# Microsoft Foundry API key. Keep this secret in Netlify.
AZURE_FOUNDRY_KEY=

# Agent name from Foundry, for example: professoria.
# AZURE_FOUNDRY_AGENT_ID is still accepted by the function as a legacy name.
AZURE_FOUNDRY_AGENT_NAME=

# Optional legacy variable. Use only if you do not set AZURE_FOUNDRY_AGENT_NAME.
AZURE_FOUNDRY_AGENT_ID=
