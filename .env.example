# Ponto de extremidade do projeto
# Azure AI Foundry > Página inicial > "Ponto de extremidade do projeto"
# Exemplo: https://XXXX.services.ai.azure.com/api/projects/NOME_DO_PROJETO
AZURE_FOUNDRY_ENDPOINT=

# Chave de API
# Azure AI Foundry > Página inicial > "Chave de API"
AZURE_FOUNDRY_KEY=

# ID do agente
# Azure AI Foundry > Agentes > clique no seu agente > copie o ID exibido na página
# Exemplo: asst_abc123xyz
AZURE_FOUNDRY_AGENT_ID=

# Versão da API do Azure AI Foundry (opcional — o padrão já está preenchido)
# Altere apenas se a Microsoft lançar uma versão mais recente
AZURE_FOUNDRY_API_VERSION=v1
